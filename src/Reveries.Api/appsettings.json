{
  "Isbndb": {
    "ApiUrl": "https://api2.isbndb.com/",
    "ApiKey": "",
    "MaxBulkIsbns": 100
  },
  "GoogleBooks": {
    "ApiUrl": "https://www.googleapis.com/books/v1/",
    "ApiKey": ""
  },
  "Postgres": {
    "Host": "postgres",
    "Port": 5432,
    "Database": "",
    "Username": "",
    "Password": "",
    "ConnectionString": "",
    "Pool": {
      "Min": 1,
      "Max": 100
    },
    "TimeoutSeconds": 15,
    "CommandTimeoutSeconds": 20
  },
  "Redis": {
    "Host": "redis",
    "Port": 6379,
    "Password": "",
    "ConnectionString": ""
  },
  "Loki": {
    "Uri": "http://loki:3100"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Grafana.Loki",
      "Serilog.Enrichers.Environment",
      "Serilog.Enrichers.Process",
      "Serilog.Enrichers.Thread",
      "Serilog.Exceptions"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithProcessId",
      "WithThreadId",
      "WithMachineName",
      "WithExceptionDetails"
    ]
  }
}
