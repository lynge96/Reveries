{
  "Isbndb": {
    "ApiUrl": "https://api2.isbndb.com/",
    "ApiKey": "",
    "MaxBulkIsbns": 100
  },
  "GoogleBooks": {
    "ApiUrl": "https://www.googleapis.com/books/v1/",
    "ApiKey": ""
  },
  "Postgres": {
    "Host": "postgres",
    "Port": 5432,
    "Database": "",
    "Username": "",
    "Password": "",
    "ConnectionString": "",
    "Pool": {
      "Min": 1,
      "Max": 100
    },
    "TimeoutSeconds": 15,
    "CommandTimeoutSeconds": 20
  },
  "Redis": {
    "Host": "redis",
    "Port": 6379,
    "Password": "",
    "ConnectionString": ""
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Grafana.Loki",
      "Serilog.Enrichers.Environment",
      "Serilog.Formatting.Compact"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Warning",
        "System.Net.Http.HttpClient": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithEnvironmentName",
      "WithProcessId",
      "WithThreadId"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "GrafanaLoki",
        "Args": {
          "uri": "http://loki:3100",
          "labels": [
            { "key": "app", "value": "reveries-api" },
            { "key": "env", "value": "local" }
          ]
        }
      }
    ]
  }
}
